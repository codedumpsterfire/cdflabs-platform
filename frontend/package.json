{
  "name": "cdflabs-3d-platform",
  "version": "1.0.0",
  "description": "3D Angular application with Blender models, GSAP animations, Spring Boot backend, and AWS services integration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:cypress": "cypress open",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,html,scss}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@angular/animations": "^18.2.14",
    "@angular/common": "^18.2.14",
    "@angular/compiler": "^18.2.14",
    "@angular/core": "^18.2.14",
    "@angular/forms": "^18.2.14",
    "@angular/platform-browser": "^18.2.14",
    "@angular/platform-browser-dynamic": "^18.2.14",
    "@angular/router": "^18.2.14",
    "@aws-sdk/client-cognito-identity": "^3.521.0",
    "@aws-sdk/client-s3": "^3.521.0",
    "@aws-sdk/credential-providers": "^3.521.0",
    "@babylonjs/loaders": "^6.31.0",
    "@babylonjs/materials": "^6.31.0",
    "axios": "^1.6.2",
    "babylonjs": "^6.31.0",
    "gsap": "^3.12.2",
    "rxjs": "^7.8.1",
    "supabase": "^2.43.0",
    "three": "0.158.0",
    "tslib": "^2.6.2",
    "zone.js": "^0.14.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^18.2.0",
    "@angular-eslint/eslint-plugin": "^18.2.0",
    "@angular-eslint/eslint-plugin-template": "^18.2.0",
    "@angular-eslint/schematics": "^18.2.0",
    "@angular-eslint/template-parser": "^18.2.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.14",
    "@testing-library/angular": "^13.1.0",
    "@types/node": "^20.10.0",
    "@types/three": "0.158.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "@vitest/coverage-v8": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "cypress": "^13.6.1",
    "eslint": "^8.55.0",
    "happy-dom": "^12.10.3",
    "playwright": "^1.40.1",
    "prettier": "^3.1.1",
    "sass": "^1.101.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
